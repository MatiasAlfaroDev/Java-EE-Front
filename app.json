{
  "expo": {
    "name": "Terotalk",
    "slug": "chatee-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#091525"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.grupo5.chatee"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#091525"
      },
      "package": "com.grupo5.chatee",
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-notifications",
        {
          "color": "#3B7DFF",
          "sounds": []
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Permite a Terotalk acceder a Face ID para autenticación segura."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Permite a Terotalk acceder a tus fotos para enviar imágenes.",
          "cameraPermission": "Permite a Terotalk usar la cámara para enviar fotos."
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "chatee",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "60259e58-1eec-487e-9a1d-d1940a8cdc3e"
      }
    },
    "owner": "cecimenca"
  }
}
