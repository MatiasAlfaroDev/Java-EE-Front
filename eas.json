{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://app-production-c142.up.railway.app/chat-empresarial/api",
        "EXPO_PUBLIC_WS_URL": "https://app-production-c142.up.railway.app"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://app-production-c142.up.railway.app/chat-empresarial/api",
        "EXPO_PUBLIC_WS_URL": "https://app-production-c142.up.railway.app"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
